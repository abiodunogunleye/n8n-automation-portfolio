        "subject": "=New Sales Enquiry from {{ $('Webhook').item.json.body.ProfileName }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; font-size: 15px; color: #333;\">\n  <h2 style=\"color: #0f766e;\">New Sales Enquiry</h2>\n  <p>A new sales enquiry has come in via WhatsApp.</p>\n  \n  <table style=\"border-collapse: collapse; width: 100%; margin-top: 12px;\">\n    <tr style=\"background-color: #f5f5f5;\">\n      <td style=\"padding: 10px; font-weight: bold; width: 140px;\">From</td>\n      <td style=\"padding: 10px;\">{{ $('Webhook').item.json.body.ProfileName }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding: 10px; font-weight: bold;\">WhatsApp</td>\n      <td style=\"padding: 10px;\">{{ $('Webhook').item.json.body.From }}</td>\n    </tr>\n    <tr style=\"background-color: #f5f5f5;\">\n      <td style=\"padding: 10px; font-weight: bold;\">Message</td>\n      <td style=\"padding: 10px;\">{{ $('Webhook').item.json.body.Body }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding: 10px; font-weight: bold;\">Classification</td>\n      <td style=\"padding: 10px; color: #0f766e; font-weight: bold;\">Sales Enquiry</td>\n    </tr>\n  </table>\n  \n  <p style=\"margin-top: 20px; color: #666;\">Please respond to this enquiry as soon as possible.</p>\n</div>",
